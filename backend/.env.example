PORT=5000
MONGODB_URI=mongodb://localhost:27017/bachat-bazaar
NODE_ENV=development

# Auth — required in production (min 32 characters). In development a default is used if unset.
JWT_SECRET=
# e.g. 15m, 1h, 7d
JWT_EXPIRES_IN=7d

# Behind nginx/ingress, set TRUST_PROXY=true so Secure cookies and IPs are correct.
TRUST_PROXY=false

# Cookie: strict | lax | none (none requires Secure).
# React on :3000 and API on :5000 are cross-site; use none + secure for cookies to be sent on fetch:
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
# In production defaults to true when NODE_ENV=production.
COOKIE_SECURE=false
